#!/usr/bin/env node
// Granted tool: post a message to Slack. Usage: slack-post '#channel-or-@user' 'message text'
// A '@handle' (or an email) is resolved to a user id and sent as a DM.
const [, , channel, ...rest] = process.argv;
const text = rest.join(' ');
const token = process.env.SLACK_BOT_TOKEN;
if (!channel || !text) { console.error("usage: slack-post '#channel-or-@user' 'message'"); process.exit(64); }
if (!token) { console.error('SLACK_BOT_TOKEN not set'); process.exit(1); }
const api = async (method, body) => {
  const res = await fetch(`https://slack.com/api/${method}`, {
    method: 'POST', headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json; charset=utf-8' },
    body: JSON.stringify(body),
  });
  return res.json();
};

// Resolve a DM target: '@fabio' or 'fabio@f1v.co' → a user id (Uxxxx), which DMs the user.
async function resolveUser(target) {
  const t = target.replace(/^@/, '').trim();
  if (t.includes('@')) { const r = await api('users.lookupByEmail?email=' + encodeURIComponent(t), {}); if (r.ok) return r.user.id; }
  let cursor = '';
  for (let i = 0; i < 20; i++) {
    const r = await api('users.list', { limit: 200, cursor });
    if (!r.ok) return null;
    const lc = t.toLowerCase();
    const m = r.members.find((u) => !u.deleted && (
      u.name?.toLowerCase() === lc ||
      u.profile?.display_name?.toLowerCase() === lc ||
      u.profile?.real_name?.toLowerCase() === lc ||
      u.profile?.email?.toLowerCase() === lc));
    if (m) return m.id;
    cursor = r.response_metadata?.next_cursor || '';
    if (!cursor) break;
  }
  return null;
}

let target = channel;
if (channel.startsWith('@') || channel.includes('@')) {
  const id = await resolveUser(channel);
  if (!id) { console.error(`could not resolve ${channel} to a Slack user (needs users:read / users:read.email scope, or try the exact handle/email)`); process.exit(2); }
  target = id;
}
const j = await api('chat.postMessage', { channel: target, text });
if (j.ok) { console.log(`posted to ${j.channel} @ ${j.ts}`); }
else if (j.error === 'not_in_channel' || j.error === 'channel_not_found') { console.error(`bot can't reach ${channel} — invite @fabio_bot there, or DM requires the user to allow bot messages`); process.exit(2); }
else { console.error(`slack error: ${j.error}`); process.exit(2); }
