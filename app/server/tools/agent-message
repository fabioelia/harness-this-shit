#!/usr/bin/env node
// Granted tool (team): delegate a task to a named agent.
//   agent-message <agent> 'the task'            → fire-and-forget, prints the run id
//   agent-message <agent> 'the task' --wait     → waits for the agent to finish and
//                                                 prints its result (so you can act on it)
const argv = process.argv.slice(2);
const wait = argv.includes('--wait');
const [name, ...rest] = argv.filter((a) => a !== '--wait');
const text = rest.join(' ');
if (!name || !text) { console.error("usage: agent-message <agent> 'the task' [--wait]"); process.exit(64); }
const port = process.env.PORT || 4317;
const base = `http://localhost:${port}`;
const res = await fetch(`${base}/api/agents/${encodeURIComponent(name)}/message`, {
  method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ text }),
});
const j = await res.json().catch(() => ({}));
if (!res.ok) { console.error(`agent-message failed: ${j.error || res.status}`); process.exit(2); }
if (!wait) { console.log(`delegated to ${name} — run ${j.runId}`); process.exit(0); }

// --wait: poll until the agent's run resolves, then print its output.
const runId = j.runId;
const deadline = Date.now() + 8 * 60_000;
const sleep = (ms) => new Promise((r) => setTimeout(r, ms));
while (Date.now() < deadline) {
  await sleep(4000);
  const r = await fetch(`${base}/api/runs/${runId}`).then((x) => x.json()).catch(() => null);
  if (!r) continue;
  if (r.status !== 'running' && r.status !== 'waiting') {
    console.log(`# ${name} (${r.status}, run ${runId}):\n${r.stdout || '(no output)'}`);
    process.exit(r.status === 'succeeded' ? 0 : 3);
  }
}
console.error(`agent-message: ${name} (run ${runId}) did not finish in time`);
process.exit(124);
