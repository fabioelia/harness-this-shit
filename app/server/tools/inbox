#!/usr/bin/env node
// Granted tool (concurrency=coalesce): fetch events that were coalesced onto THIS run's
// plate while it was working. Usage: inbox   (claims + prints any new tasks)
const runId = process.env.SB_RUN_ID;
const port = process.env.PORT || 4317;
if (!runId) { console.log('inbox: no run context (SB_RUN_ID unset)'); process.exit(0); }
const res = await fetch(`http://localhost:${port}/api/runs/${runId}/inbox`, { method: 'POST' });
const j = await res.json().catch(() => ({ tasks: [] }));
const tasks = j.tasks || [];
if (!tasks.length) { console.log('inbox empty — nothing new landed. Safe to wrap up.'); process.exit(0); }
console.log(`${tasks.length} new task${tasks.length > 1 ? 's' : ''} coalesced onto this run — handle these too, then run \`inbox\` again:`);
for (const t of tasks) console.log(`- ${t.summary}`);
console.log('\nEvent payloads:');
console.log(JSON.stringify(tasks.map((t) => t.event), null, 2));
