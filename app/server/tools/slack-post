#!/usr/bin/env node
// Granted tool: post a message to Slack. Usage: slack-post '#channel-or-@user' 'message text'
const [, , channel, ...rest] = process.argv;
const text = rest.join(' ');
const token = process.env.SLACK_BOT_TOKEN;
if (!channel || !text) { console.error("usage: slack-post '#channel' 'message'"); process.exit(64); }
if (!token) { console.error('SLACK_BOT_TOKEN not set'); process.exit(1); }
const res = await fetch('https://slack.com/api/chat.postMessage', {
  method: 'POST',
  headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json; charset=utf-8' },
  body: JSON.stringify({ channel, text }),
});
const j = await res.json();
if (j.ok) { console.log(`posted to ${j.channel} @ ${j.ts}`); }
else if (j.error === 'not_in_channel' || j.error === 'channel_not_found') { console.error(`bot not in ${channel} — run "/invite @fabio_bot" there once`); process.exit(2); }
else { console.error(`slack error: ${j.error}`); process.exit(2); }
